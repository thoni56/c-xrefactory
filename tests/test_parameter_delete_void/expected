CXREF -xrefactory-II -server -o server-buffer
-olcxgetprojectname CURDIR/hello.c
end-of-options

<sync>
<set-info len=<n>>CURDIR</set-info>
-rfct-del-param -olcxparnum=1 -olcursor=17 CURDIR/hello.c -p CURDIR
end-of-options

<sync>
<goto>
 <position-off off=17 len=<n>>CURDIR/hello.c</position-off>
</goto>
<ask-confirmation len=<n>>Can not parse parameter definition, continue anyway?</ask-confirmation>
<error len=<n>>Parameter number out of limits
</error>
<goto>
 <position-off off=21 len=<n>>CURDIR/hello.c</position-off>
</goto>
<replacement>
 <str len=<n>>void</str>  <str len=<n>></str>
</replacement>
<goto>
 <position-off off=17 len=<n>>CURDIR/hello.c</position-off>
</goto>
-exit
end-of-options

