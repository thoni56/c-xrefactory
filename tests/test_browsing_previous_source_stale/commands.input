CXREF -xrefactory-II -server
-getproject CURDIR/source.c
<sync>
-push -preload CURDIR/source.c CURDIR/source.preload -preload CURDIR/header.h CURDIR/header.preload -olcursor=50 CURDIR/source.c -p CURDIR
<sync>
-browse-next -preload CURDIR/source.c CURDIR/source.preload -preload CURDIR/header.h CURDIR/header.preload -olcursor=39 CURDIR/header.h -p CURDIR
<sync>
-browse-next -preload CURDIR/source.c CURDIR/source.preload -preload CURDIR/header.h CURDIR/header.preload -olcursor=90 CURDIR/header.h -p CURDIR
<sync>
-browse-previous -preload CURDIR/source.c CURDIR/source.modified -preload CURDIR/header.h CURDIR/header.preload -olcursor=50 CURDIR/source.c -p CURDIR
<sync>
<exit>
