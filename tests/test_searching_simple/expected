CXREF -xrefactory-II -server -o server-buffer
-getproject CURDIR/source.c
end-of-options

<sync>
<set-info len=<n>>CURDIR</set-info>
-search=int* -olcxlccursor=1:5 -olcursor=5 CURDIR/source.c -olcursor=85 -p CURDIR
end-of-options

<sync>
<wait-confirmation len=<n>>1 of 1 compilation units need reparsing. Parse all before searching?</wait-confirmation>
-continue
end-of-options

<sync>
<symbol-list>
 <str len=<n>>int_which_is_public :source.c :CURDIR/source.c</str>
 <str len=<n>>int_which_is_static :source.c :CURDIR/source.c</str>
</symbol-list>
-exit
end-of-options

