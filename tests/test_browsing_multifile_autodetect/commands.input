CXREF -xrefactory-II -server
-getproject CURDIR/source1.c
<sync>
-push -olcursor=35 CURDIR/common.h -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-browse-next -olcursor=32 CURDIR/common.h -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-browse-next -olcursor=22 CURDIR/source1.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-browse-next -olcursor=22 CURDIR/source2.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxpop -olcursor=22 CURDIR/source2.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-push -preload CURDIR/common.h CURDIR/common.preload -olcursor=35 CURDIR/common.h -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-browse-next -preload CURDIR/common.h CURDIR/common.preload -olcursor=32 CURDIR/common.h -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-browse-next -olcursor=22 CURDIR/source1.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-browse-next -olcursor=22 CURDIR/source2.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
<exit>
