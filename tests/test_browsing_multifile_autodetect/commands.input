CXREF -xrefactory-II -server
-olcxgetprojectname CURDIR/source1.c
<sync>
-olcxpush -olcursor=35 CURDIR/common.h -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxnext -olcursor=32 CURDIR/common.h -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxnext -olcursor=22 CURDIR/source1.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxnext -olcursor=22 CURDIR/source2.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxpop -olcursor=22 CURDIR/source2.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxpush -preload CURDIR/common.h CURDIR/common.preload -olcursor=35 CURDIR/common.h -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxnext -preload CURDIR/common.h CURDIR/common.preload -olcursor=32 CURDIR/common.h -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxnext -olcursor=22 CURDIR/source1.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
-olcxnext -olcursor=22 CURDIR/source2.c -xrefrc CURDIR/.c-xrefrc -p CURDIR
<sync>
<exit>
