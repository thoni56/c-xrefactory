CXREF -xrefactory-II -server
-getproject CURDIR/source.c
<sync>
-push -preload CURDIR/source.c CURDIR/source.preload -preload CURDIR/inner.h CURDIR/inner.preload -olcursor=48 CURDIR/source.c -p CURDIR
<sync>
-browse-next -preload CURDIR/source.c CURDIR/source.preload -preload CURDIR/inner.h CURDIR/inner.preload -olcursor=37 CURDIR/inner.h -p CURDIR
<sync>
-browse-next -preload CURDIR/source.c CURDIR/source.preload -preload CURDIR/inner.h CURDIR/inner.preload -olcursor=88 CURDIR/inner.h -p CURDIR
<sync>
-browse-previous -preload CURDIR/source.c CURDIR/source.preload -preload CURDIR/inner.h CURDIR/inner.modified -olcursor=48 CURDIR/source.c -p CURDIR
<sync>
<exit>
