CXREF -xrefactory-II -crlfconversion -crconversion -server
-getproject source.c
<sync>
-push -olcursor=4 source.c
<sync>
-browse-next source.c
<sync>
-olcxpushonly -olnodialog -olcursor=56 source.c
<sync>
-browse-next source.c
<sync>
-olcxpoponly -olnodialog source.c
<sync>
-browse-next source.c
<sync>
<exit>
